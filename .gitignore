# Allowlisting gitignore template for projects prevents us
# from adding various unwanted local files, such as generated
# files, developer configurations or IDE-specific files etc.

# Ignore everything
*

# But not these files...
!/.gitignore
!/.gitmodules

# PDF with project instruction
!project_instructions.pdf

# Report submodule
!report
!report/**

!README.md
!LICENSE
!Makefile

# Nix
!*.nix
!flake.lock
!.envrc

# Source code
!*.c
!*.h
!*.py
!*.json
!*.dot
!*.md

# Don't track build outputs / Python caches
__pycache__/
*.o
*.pyc

# ...even if they are in subdirectories
!*/
.claude/settings.local.json
